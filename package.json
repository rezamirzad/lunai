{
  "name": "lunai-monorepo-template",
  "version": "0.1.0",
  "private": true,
  "description": "Fullstack monorepo template with Next.js and Express",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:web": "npm run dev --workspace=@workspace/web",
    "dev:api": "npm run dev --workspace=@workspace/api",
    "build:all": "npm run build --workspaces",
    "install:all": "npm install"
  },
  "keywords": [
    "monorepo",
    "template",
    "typescript",
    "nextjs",
    "express"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^12.8.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^20.19.39",
    "typescript": "^5.4.5",
    "eslint": "^8.57.0"
  }
}
